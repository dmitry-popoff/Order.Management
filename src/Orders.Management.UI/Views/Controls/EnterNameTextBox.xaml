<UserControl x:Class="Orders.Management.UI.Views.Controls.EnterNameTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Orders.Management.UI.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="root">
    <Grid>
        <TextBox x:Name="theTextBox" 
                 Text="{Binding NameText, ElementName=root, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            PreviewTextInput="LettersOnlyTextBox_PreviewTextInput" 
             DataObject.Pasting="LettersOnlyTextBox_Pasting"/>
    </Grid>
</UserControl>
