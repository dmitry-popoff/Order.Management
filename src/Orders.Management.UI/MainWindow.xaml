<Window x:Class="Orders.Management.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Orders.Management.UI"
        xmlns:vm="clr-namespace:Orders.Management.UI.ViewModels"
        xmlns:view="clr-namespace:Orders.Management.UI.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="522" Width="912"
        >
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:NavigationViewModel}">
            <view:Navigation />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeesViewModel}">
            <view:EmployeesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CounterpartiesViewModel}">
            <view:CounterpartiesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
            <view:OrdersView />
        </DataTemplate>
    </Window.Resources>
    <DockPanel>
        <Grid Background="Blue" >
            <ContentControl Width="200"
                DockPanel.Dock="Left" 
                            Content="{Binding Path=Navigation}" />
        </Grid>
        <ContentControl Content="{Binding Path=CurrentViewModel}"></ContentControl>
    
    </DockPanel>
</Window>
